@page
@model MoonlightSquad.Pages.Admin.NewsModel
@{
    ViewData["Title"] = "Gestion des Nouvelles";
}

<div class="container mt-5">
    <div class="main-content">
        <h1 class="mb-4">Gestion des Nouvelles</h1>

        <!-- Bouton pour créer une nouvelle -->
        @if (!Model.ShowForm)
        {
            <div class="mb-4">
                <a href="?editId=" class="btn btn-primary" style="background-color: #ff00ff; border-color: #ff00ff;">
                    ➕ Créer une nouvelle
                </a>
            </div>
        }

        <!-- Formulaire de création/modification -->
        @if (Model.ShowForm)
        {
            <div class="card mb-4" style="background-color: rgba(15, 15, 35, 0.9); border: 2px solid #00ffff;">
                <div class="card-body">
                    <h2 class="card-title" style="color: #00ffff;">
                        @(Model.EditId.HasValue ? "Modifier une nouvelle" : "Créer une nouvelle")
                    </h2>

                    <form method="post" asp-page-handler="Save">
                        <input type="hidden" asp-for="EditId" />

                        <div class="mb-3">
                            <label for="title" class="form-label" style="color: #00ffff;">Titre</label>
                            <input type="text" asp-for="Title" class="form-control" placeholder="Titre de la nouvelle" required>
                            <span asp-validation-for="Title" class="text-danger"></span>
                        </div>

                        <div class="mb-3">
                            <label for="content" class="form-label" style="color: #00ffff;">Contenu</label>
                            <textarea asp-for="Content" class="form-control" rows="6" placeholder="Contenu de la nouvelle" required></textarea>
                            <span asp-validation-for="Content" class="text-danger"></span>
                        </div>

                        <div class="mb-3">
                            <label for="imageUrl" class="form-label" style="color: #00ffff;">URL de l'image</label>
                            <input type="url" asp-for="ImageUrl" class="form-control" placeholder="https://...">
                        </div>

                        <div class="row">
                            <div class="col-md-6 mb-3">
                                <label for="isActive" class="form-check-label" style="color: #00ffff;">
                                    <input type="checkbox" asp-for="IsActive" class="form-check-input">
                                    Actif
                                </label>
                            </div>

                            <div class="col-md-6 mb-3">
                                <label for="order" class="form-label" style="color: #00ffff;">Ordre d'affichage</label>
                                <input type="number" asp-for="Order" class="form-control" min="0">
                            </div>
                        </div>

                        <div class="d-flex gap-2">
                            <button type="submit" class="btn btn-success" style="background-color: #00ff00; border-color: #00ff00; color: black;">
                                ✓ Enregistrer
                            </button>
                            <a asp-page="News" class="btn btn-secondary" style="background-color: #666; border-color: #666;">
                                ✕ Annuler
                            </a>
                        </div>
                    </form>
                </div>
            </div>
        }

        <!-- Liste des nouvelles -->
        <div>
            <h2 style="color: #00ffff; margin-top: 2rem;">Liste des nouvelles (@Model.NewsList.Count)</h2>

            @if (Model.NewsList.Any())
            {
                <div class="table-responsive">
                    <table class="table" style="color: #00ffff; border-color: #ff00ff;">
                        <thead style="border-bottom: 2px solid #ff00ff;">
                            <tr>
                                <th>Titre</th>
                                <th>Date</th>
                                <th>Statut</th>
                                <th>Ordre</th>
                                <th>Actions</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var news in Model.NewsList)
                            {
                                <tr style="border-bottom: 1px solid rgba(255, 0, 255, 0.2);">
                                    <td>@news.Title</td>
                                    <td>@news.CreatedAt.ToString("dd/MM/yyyy HH:mm")</td>
                                    <td>
                                        <span class="badge" style="background-color: @(news.IsActive ? "#00ff00" : "#ff0000");">
                                            @(news.IsActive ? "Actif" : "Inactif")
                                        </span>
                                    </td>
                                    <td>@news.Order</td>
                                    <td>
                                        <a asp-page="News" asp-route-editId="@news.Id" class="btn btn-sm btn-warning" style="background-color: #ffff00; color: black; border: none;">
                                            ✎ Modifier
                                        </a>
                                        <form method="post" asp-page-handler="Delete" style="display: inline;">
                                            <input type="hidden" name="id" value="@news.Id" />
                                            <button type="submit" class="btn btn-sm btn-danger" style="background-color: #ff0000; border: none;" onclick="return confirm('Voulez-vous vraiment supprimer cette nouvelle?');">
                                                🗑️ Supprimer
                                            </button>
                                        </form>
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            }
            else
            {
                <div class="alert alert-info" style="background-color: rgba(0, 255, 255, 0.1); border-color: #00ffff; color: #00ffff;">
                    Aucune nouvelle pour le moment. <a asp-page="News" style="color: #ff00ff;">Créez-en une!</a>
                </div>
            }
        </div>
    </div>
</div>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
}
