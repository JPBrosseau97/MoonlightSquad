@page
@model IndexModel
@{
    ViewData["Title"] = "Moonlight Squad";
}

<style>
    .carousel-item {
        height: 25rem;
        background-position: center;
        background-size: cover;
    }

    .headline-container {
        padding: 1rem;
        background: linear-gradient(180deg, rgba(15, 15, 35, 0.95) 0%, rgba(15, 15, 35, 0.85) 100%);
        border-top: 2px solid #ff00ff;
    }

    .headline-container h1 {
        color: #00ffff;
        text-shadow: 0 0 10px #ff00ff;
    }

    .headline-container p {
        color: #d6dbd6;
    }
</style>

<div id="carousel-headlines" class="carousel slide" data-bs-ride="carousel">
    <div class="carousel-inner">
        @if (Model.News.Any())
        {
            <ol class="carousel-indicators">
                @for (int i = 0; i < Model.News.Count; i++)
                {
                    <li data-bs-target="#carousel-headlines" data-bs-slide-to="@i" class="@(i == 0 ? "active" : "")"></li>
                }
            </ol>

            @for (int i = 0; i < Model.News.Count; i++)
            {
                var news = Model.News[i];
                <div class="carousel-item @(i == 0 ? "active" : "")" 
                     @if (!string.IsNullOrEmpty(news.ImageUrl))
                     {
                         @:style="background-image:url(@news.ImageUrl)"
                     }>
                    <div class="headline-container">
                        <h1>@news.Title</h1>
                        <p>@news.Content.Substring(0, Math.Min(150, news.Content.Length))@(news.Content.Length > 150 ? "..." : "")</p>
                    </div>
                </div>
            }
        }
        else
        {
            <div class="carousel-item active" style="background-image:url(https://www.fdli.org/wp-content/uploads/2018/11/Unstacking-Class-Action-Janssen-800x450.jpg)">
                <div class="headline-container">
                    <h1>Bienvenue sur Moonlight Squad</h1>
                    <p>Aucune nouvelle pour le moment. Revenez bientôt!</p>
                </div>
            </div>
        }
    </div>
</div>

<div class="row mt-4">
    <div class="col-md-12">
        <h2>Bienvenue sur le site de la Moonlight Squad!</h2>
        <p>Nous sommes un équipe d'airsoft basé à Montréal, Québec. Nous participons à tout les événements de Airsoft et de Milsim au travers du Québec et en Ontario. Au plaisir de vous rencontrer sur le terrain!</p>
    </div>

</div>